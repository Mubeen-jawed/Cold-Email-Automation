# Copy this to .env.production and fill in your values
# This file is loaded by the systemd service

# Required: OpenRouter API key for email generation
OPENROUTER_API_KEY=your_openrouter_key_here

# Port the web server listens on (default: 8000)
PORT=8000

# Optional: base64-encoded credential files (if not uploading files directly)
# Generate with: base64 -w0 credentials.json
# GOOGLE_CREDENTIALS_B64=...
# GMAIL_CREDENTIALS_B64=...
# GMAIL_TOKEN_B64=...
